<%- include('partials/header') %>
<body>
    <main class="play-container">
        <h2 class="play-title">Play</h2>

        <!-- Form to create a session -->
        <form action="/create-session" method="POST" class="play-form">
            <button type="submit" class="play-button">Create Session</button>
        </form>

        <!-- Form to join a session -->
        <form action="/join-session" method="GET" class="play-form">
            <button type="submit" class="play-button">Join Session</button>
        </form>

        <!-- Form to view rules -->
        <form action="/rules" method="GET" class="play-form">
            <button type="submit" class="play-button">View Rules</button>
        </form>
    </main>
    <%- include('partials/footer') %>
</body>
