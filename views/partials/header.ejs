<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3-5-7 Poker Game</title>
    <link rel="stylesheet" href="/style.css"> <!-- Link to your CSS file -->
</head>
<body>
    <header class="header">
        <div class="header-content">
            <h1 class="title">
                <a href="/" class="title-link">3-5-7 Poker Game</a>
            </h1>
            <nav class="nav">
                <% if (session.userId) { %>
                    <div class="greeting">Hi <%= session.username %></div> <!-- Username on the left -->
                    <a href="/logout" class="nav-item">Logout</a>
                <% } else {%>
                <div class="nav-links"> <!-- A separate div for the nav links -->
                    
                    <a href="/register" class="nav-item">Register</a>
                    <a href="/login" class="nav-item">Login</a>
                <% } %>
                <a href="/" class="nav-item">Home</a>
                </div>
            </nav>
        </div>
    </header>
    <!-- Other content of your page goes here -->
</body>
</html>
